{
  "manifest_version": 3,
  "name": "Instant Breakdown AI",
  "version": "1.0.0",
  "description": "Instantly break down complex content anywhere on the web with AI.",
  
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],



  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "host_permissions": [
    "http://localhost:5000/*"
  ]
}